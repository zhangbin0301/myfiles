      case "${NEZHA_VERSION}" in
        "V0" )
          if [[ " ${tlsPorts[@]} " =~ " ${NEZHA_PORT} " ]]; then
            NEZHA_TLS="--tls"
          else
            NEZHA_TLS=""
          fi
          ;;
        "V1" )
          if [[ " ${tlsPorts[@]} " =~ " ${NEZHA_PORT} " ]]; then
            NEZHA_TLS="true"
          else
            NEZHA_TLS="false"
          fi
          cat > ${FILE_PATH}/config.yml << ABC
client_secret: $NEZHA_KEY
debug: false
disable_auto_update: true
disable_command_execute: false
disable_force_update: true
disable_nat: false
disable_send_query: false
gpu: false
insecure_tls: false
ip_report_period: 1800
report_delay: 4
server: $NEZHA_SERVER:$NEZHA_PORT
skip_connection_count: false
skip_procs_count: false
temperature: false
tls: $NEZHA_TLS
use_gitee_to_upgrade: false
use_ipv6_country_code: false
uuid: $UUID
ABC
          ;;
      esac
    }
    nezhacfg
  fi

  generate_config
  argo_type
  args
}

# run
run_argo() {
  ${FILE_PATH}/${argo_randomness} ${args} >/dev/null 2>&1 &
}

run_web() {
  ${FILE_PATH}/${web_randomness} run -c ${FILE_PATH}/out.json >/dev/null 2>&1 &
}

run_npm() {
  case "${NEZHA_VERSION}" in
    "V0" )
      ${FILE_PATH}/${npm_randomness} -s ${NEZHA_SERVER}:${NEZHA_PORT} -p ${NEZHA_KEY} ${NEZHA_TLS} --report-delay=4 --skip-conn --skip-procs --disable-auto-update >/dev/null 2>&1 &
      ;;
    "V1" )
      ${FILE_PATH}/${npm_randomness} -c ${FILE_PATH}/config.yml >/dev/null 2>&1 &
      ;;
  esac
}

Detect_process() {
  local process_name="$1"
  local pids=""
  if command -v pidof >/dev/null 2>&1; then
    pids=$(pidof "$process_name" 2>/dev/null)
  elif command -v ps >/dev/null 2>&1; then
    pids=$(pgrep -x "$process_name" 2>/dev/null)
  elif command -v pgrep >/dev/null 2>&1; then
    pids=$(ps -eo pid,comm | awk -v name="$process_name" '$2 == name {print $1}')
  fi
  [ -n "$pids" ] && echo "$pids"
}

keep_alive() {
  while true; do
    if [ -e "${FILE_PATH}/${argo_randomness}" ] && [ -z "$(Detect_process "${argo_randomness}")" ]; then
      run_argo
    fi
    sleep 5
    if [ -e "${FILE_PATH}/${web_randomness}" ] && [ -z "$(Detect_process "${web_randomness}")" ]; then
      run_web
    fi
    sleep 5
    if [ -e "${FILE_PATH}/${npm_randomness}" ] && [ -n "${NEZHA_SERVER}" ] && [ -n "${NEZHA_KEY}" ] && [ -z "$(Detect_process "${npm_randomness}")" ]; then
      run_npm
    fi
    sleep 50
  done
}

run_processes() {
  argo_randomness=tmp$(dd if=/dev/urandom bs=1 count=100 2>/dev/null | tr -dc 'A-Za-z0-9' | head -c 3)
  web_randomness=tmp$(dd if=/dev/urandom bs=1 count=100 2>/dev/null | tr -dc 'A-Za-z0-9' | head -c 3)
  npm_randomness=tmp$(dd if=/dev/urandom bs=1 count=100 2>/dev/null | tr -dc 'A-Za-z0-9' | head -c 3)
  # argo_randomness=tmp$(tr -dc 'A-Za-z0-9' </dev/urandom 2>/dev/null | head -c 3)
  # web_randomness=tmp$(tr -dc 'A-Za-z0-9' </dev/urandom 2>/dev/null | head -c 3)
  # npm_randomness=tmp$(tr -dc 'A-Za-z0-9' </dev/urandom 2>/dev/null | head -c 3)

  if [ -e "${FILE_PATH}/argo" ]; then
    mv ${FILE_PATH}/argo ${FILE_PATH}/${argo_randomness} && sleep 1
    run_argo
    red "argo is running !"
    sleep 5
  fi
  if [ -e "${FILE_PATH}/web" ]; then
    mv ${FILE_PATH}/web ${FILE_PATH}/${web_randomness} && sleep 1
    run_web
    red "web is running !"
    sleep 1
  fi
  if [ -n "${NEZHA_SERVER}" ] && [ -n "${NEZHA_KEY}" ] && [ -e "${FILE_PATH}/npm" ]; then
    mv ${FILE_PATH}/npm ${FILE_PATH}/${npm_randomness} && sleep 1
    run_npm
    red "npm is running !"
    sleep 1
  fi

  check_hostname_change && sleep 2
  purple "ARGO_DOMAIN: $ARGO_DOMAIN"
  if [ -n "$SUB_URL" ]; then
    upload >/dev/null 2>&1 &
  else
    build_urls
  fi

  sleep 3
  purple "\nvps节点链接如下：\n"
  cat ${FILE_PATH}/tmp.txt

  if [ "${KEEPALIVE}" = "1" ]; then
    keep_alive 2>&1 &
  elif [ "${KEEPALIVE}" = "0" ]; then
    sleep 5
    rm -rf ${FILE_PATH}/${argo_randomness} ${FILE_PATH}/${web_randomness} ${FILE_PATH}/${npm_randomness} ${FILE_PATH}/*.json ${FILE_PATH}/*.yml ${FILE_PATH}/tunnel.*
  fi
}

# ============================
#  获取 IP + ISP + 国家 Emoji
# ============================

get_ip_info() {
    local url parser_ip parser_country parser_org json

    # 1. ip.sb
    url="https://api.ip.sb/geoip"
    json=$(curl -s --max-time 5 "$url")
    if [[ -n "$json" && "$json" == *"ip"* ]]; then
        MYIP=$(echo "$json" | sed -n 's/.*"ip": *"\([^"]*\).*/\1/p')
        COUNTRY_CODE=$(echo "$json" | sed -n 's/.*"country_code": *"\([^"]*\).*/\1/p')
        ISP_NAME=$(echo "$json" | sed -n 's/.*"isp": *"\([^"]*\).*/\1/p')
        [[ -n "$MYIP" ]] && return 0
    fi

    # 2. ip-api.com
    url="http://ip-api.com/json/"
    json=$(curl -s --max-time 5 "$url")
    if [[ -n "$json" && "$json" == *"query"* ]]; then
        MYIP=$(echo "$json" | sed -n 's/.*"query": *"\([^"]*\).*/\1/p')
        COUNTRY_CODE=$(echo "$json" | sed -n 's/.*"countryCode": *"\([^"]*\).*/\1/p')
        ISP_NAME=$(echo "$json" | sed -n 's/.*"isp": *"\([^"]*\).*/\1/p')
        [[ -n "$MYIP" ]] && return 0
    fi

    return 1
}

# ============================
#  获取国家 Emoji（Promise.any 等价）
# ============================

get_country_emoji() {
    local emoji="🇺🇳 联合国"
    local text=""

    # 尝试两个服务，任意一个成功就用
    text=$(curl -s --max-time 5 https://ipconfig.de5.net)
    if [[ -z "$text" ]]; then
        text=$(curl -s --max-time 5 https://emoji.dpdns.org/)
    fi

    [[ -n "$text" ]] && emoji=$(echo "$text" | tr -d '\n' | sed 's/ *$//')

    COUNTRY_EMOJI="$emoji"
}

# ============================
#  主函数（完全等价 JS getipandisp）
# ============================

getipandisp() {
    MYIP=""
    ISP_NAME=""
    COUNTRY_CODE=""
    COUNTRY_EMOJI=""

    if ! get_ip_info; then
        ISP="🇺🇳 联合国_UnknownISP"
        MYIP="Unknown"
        echo "[IP查询失败] ISP=$ISP, IP=$MYIP"
        return 1
    fi

    # 获取 Emoji
    get_country_emoji

    # 清理 ISP 名称
    ISP_CLEAN=$(echo "$ISP_NAME" | sed -e 's/[ ,\.]/_/g; s/__*/_/g; s/^_//; s/_$//')

    # IPv6 包装
    if [[ "$MYIP" == *:* ]]; then
        MYIP="[$MYIP]"
    fi

    ISP="${COUNTRY_EMOJI}_${ISP_CLEAN}"

    echo "[IP查询成功] ISP: $ISP, IP: $MYIP"
    return 0
}


# check_hostname
check_hostname_change() {
  if [ -s "${FILE_PATH}/boot.log" ]; then
    export ARGO_DOMAIN=$(cat ${FILE_PATH}/boot.log | grep -o "info.*https://.*trycloudflare.com" | sed "s@.*https://@@g" | tail -n 1)
  fi
  export vless_url="vless://${UUID}@${CF_IP}:${CFPORT}?host=${ARGO_DOMAIN}&path=%2F${VLESS_WSPATH}%3Fed%3D2560&type=ws&encryption=none&security=tls&sni=${ARGO_DOMAIN}#${ISP}-${SUB_NAME}"
  export UPLOAD_DATA="$vless_url"
}

# build_urls
build_urls() {
  if [ -n "${UPLOAD_DATA}" ]; then
    echo -e "${UPLOAD_DATA}" > "${FILE_PATH}/tmp.txt"
  fi
}

# upload
upload_subscription() {
  if command -v curl &> /dev/null; then
    response=$(curl -s -X POST -H "Content-Type: application/json" -d "{\"URL_NAME\":\"$SUB_NAME\",\"URL\":\"$UPLOAD_DATA\"}" $SUB_URL)
  elif command -v wget &> /dev/null; then
    response=$(wget -qO- --post-data="{\"URL_NAME\":\"$SUB_NAME\",\"URL\":\"$UPLOAD_DATA\"}" --header="Content-Type: application/json" $SUB_URL)
  fi
}

export previousargoDomain=""
upload() {
  if [ ${KEEPALIVE} = "1" ] && [ -z "${ARGO_AUTH}" ]; then
    while true; do
      if [[ "$previousargoDomain" != "$ARGO_DOMAIN" ]]; then
        upload_subscription
        build_urls
        export previousargoDomain="$ARGO_DOMAIN"
      fi
      sleep 60
      check_hostname_change && sleep 2
    done
  else
    upload_subscription
    build_urls
  fi
}

# install_xray
install_xray() {
  pkill sleep
  pkill tmp
  createfolder
  cleanup_files
  initialize_downloads
  getipandisp()
  my_config
  run_processes
}

# remove_xray
remove_xray() {
  pkill sleep
  pkill tmp
  rm -rf ${FILE_PATH}
  pkill bash
}

